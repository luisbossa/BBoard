<%- include("partials/header") %>

    <div class="main-content">

        <div class="box">

            <div class="dashboard-card-header header-flex">

                <div class="mail-title">
                    <span class="material-symbols-rounded">mail</span>
                    <span>Correo</span>
                    <span class="mail-count">12</span>
                </div>

                <div class="mail-tools">
                    <input type="text" placeholder="Buscar mensaje..." class="mail-search">
                </div>

            </div>


            <div class="mail-layout">

                <!-- SIDEBAR MENSAJES -->

                <div class="mail-list">

                    <div class="mail-item unread">

                        <div class="mail-avatar">
                            <span class="material-symbols-rounded">person</span>
                        </div>

                        <div class="mail-content">

                            <div class="mail-row">
                                <strong>Juan Pérez</strong>
                                <span class="mail-time">Hoy</span>
                            </div>

                            <div class="mail-subject">
                                Consulta pedido #1004
                            </div>

                            <div class="mail-preview">
                                Hola, quisiera saber cuándo llegará mi pedido.
                            </div>

                        </div>

                    </div>


                    <div class="mail-item">

                        <div class="mail-avatar">
                            <span class="material-symbols-rounded">person</span>
                        </div>

                        <div class="mail-content">

                            <div class="mail-row">
                                <strong>Ana Gómez</strong>
                                <span class="mail-time">Ayer</span>
                            </div>

                            <div class="mail-subject">
                                Disponibilidad de producto
                            </div>

                            <div class="mail-preview">
                                ¿Tienen disponible la blusa en talla M?
                            </div>

                        </div>

                    </div>


                    <div class="mail-item">

                        <div class="mail-avatar">
                            <span class="material-symbols-rounded">person</span>
                        </div>

                        <div class="mail-content">

                            <div class="mail-row">
                                <strong>Carlos Ruiz</strong>
                                <span class="mail-time">2 días</span>
                            </div>

                            <div class="mail-subject">
                                Consulta envío
                            </div>

                            <div class="mail-preview">
                                Mi pedido aún no llega.
                            </div>

                        </div>

                    </div>

                </div>


                <!-- MENSAJE ABIERTO -->

                <div class="mail-view">

                    <div class="mail-view-header">

                        <div class="mail-user">

                            <div class="mail-avatar big">
                                <span class="material-symbols-rounded">person</span>
                            </div>

                            <div>
                                <div class="mail-name">
                                    Juan Pérez
                                </div>

                                <div class="mail-meta">
                                    juan@email.com • Hoy
                                </div>
                            </div>

                        </div>

                    </div>


                    <div class="mail-body">

                        <p>
                            Hola, quisiera saber cuándo llegará mi pedido #1004.
                        </p>

                        <p>
                            Quedo atento. Gracias.
                        </p>

                    </div>


                    <div class="mail-reply">

                        <textarea placeholder="Escribe tu respuesta..."></textarea>

                        <div class="mail-actions">

                            <button class="btn-action approve">
                                Enviar respuesta
                            </button>

                            <button class="btn-action">
                                Marcar leído
                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>