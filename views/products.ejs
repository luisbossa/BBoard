<%- include("partials/header") %>

    <div class="main-content">

        <div class="box">

            <div class="dashboard-card-header header-flex">

                <span class="title">Lista de productos</span>

                <div class="header-actions">

                    <input type="text" placeholder="Buscar producto..." class="search-input">

                    <a href="/dashboard/add-product" class="btn-primary">
                        Agregar producto
                    </a>

                </div>

            </div>

            <div class="dashboard-card-body">

                <div class="table-wrapper">

                    <table class="products-table">

                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th class="center">Precio</th>
                                <th class="center">Stock</th>
                                <th class="center">Estado</th>
                                <th class="right">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>

                            <tr>

                                <td>
                                    <div class="product-cell">

                                        <img src="/images/swimwears/swimwear-2.webp">

                                        <div class="product-meta">
                                            <span class="product-name">Vestido Floral</span>
                                            <span class="product-sku">SKU: VF-1001</span>
                                        </div>

                                    </div>
                                </td>

                                <td class="center">₡15,000</td>

                                <td class="center">32</td>

                                <td class="center">
                                    <span class="status active">Activo</span>
                                </td>

                                <td class="right">

                                    <div class="table-actions">
                                        <button class="btn-table">Editar</button>
                                        <button class="btn-table delete">Eliminar</button>
                                    </div>

                                </td>

                            </tr>


                            <tr>

                                <td>
                                    <div class="product-cell">

                                        <img src="/images/swimwears/swimwear-1.webp">

                                        <div class="product-meta">
                                            <span class="product-name">Blusa Elegante</span>
                                            <span class="product-sku">SKU: BL-2301</span>
                                        </div>

                                    </div>
                                </td>

                                <td class="center">₡9,500</td>

                                <td class="center">12</td>

                                <td class="center">
                                    <span class="status warning">Bajo stock</span>
                                </td>

                                <td class="right">

                                    <div class="table-actions">
                                        <button class="btn-table">Editar</button>
                                        <button class="btn-table delete">Eliminar</button>
                                    </div>

                                </td>

                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>